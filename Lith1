    let questionsPool = [];
    let currentQuestion = null;

    function shuffleArray(array) {
        for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
        }
    }

    function loadQuestion() {
        if (questionsPool.length === 0) {
            questionsPool = [...allQuestions];
        }

        const randomIndex = Math.floor(Math.random() * questionsPool.length);
        currentQuestion = questionsPool[randomIndex];
        questionsPool.splice(randomIndex, 1);

        let options = [...currentQuestion.options];
        shuffleArray(options);

        document.getElementById("sentence").innerText = currentQuestion.sentence;
        document.getElementById("feedback").innerText = "";
        document.getElementById("next-btn").style.display = "none";

        const container = document.getElementById("options-container");
        container.innerHTML = ""; 
        
        options.forEach(option => {
            const btn = document.createElement("button");
            btn.innerText = option;
            btn.onclick = () => checkAnswer(btn, option);
            container.appendChild(btn);
        });
    }

    function checkAnswer(clickedBtn, selectedOption) {
        const correct = currentQuestion.answer;
        
        // Вот здесь была сломана решетка! Теперь всё верно.
        const buttons = document.querySelectorAll("#options-container button");

        buttons.forEach(btn => btn.disabled = true);

        if (selectedOption === correct) {
            clickedBtn.classList.add("correct");
            document.getElementById("feedback").innerText = "Teisingai! (Правильно)";
            document.getElementById("feedback").style.color = "green";
            
            let completed = currentQuestion.sentence.replace("___", "[" + correct + "]");
            document.getElementById("sentence").innerText = completed;
        } else {
            clickedBtn.classList.add("wrong");
            document.getElementById("feedback").innerText = "Klaida! Правильный ответ: " + correct;
            document.getElementById("feedback").style.color = "red";
            
            buttons.forEach(btn => {
                if (btn.innerText === correct) btn.classList.add("correct");
            });
        }

        document.getElementById("next-btn").style.display = "block";
    }

    window.onload = loadQuestion;
</script>

</body>
</html>
