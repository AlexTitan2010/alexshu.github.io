        .wrong { background-color: #ef9a9a !important; border-color: #f44336 !important; color: #000; }
        
        #feedback { font-size: 18px; margin-top: 25px; font-weight: bold; height: 25px;}
        
        #next-btn {
            display: none;
            margin: 20px auto 0;
            background-color: #2196F3;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
        }
        #next-btn:hover { background-color: #1976D2; }
    </style>
</head>
